# Server
NODE_ENV=development
PORT=8080
MONGO_URI=
JWT_SECRET=
JWT_REFRESH_SECRET=

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=

# Admin Panel
ADMIN_PANEL_URL=http://localhost:5173

# Website URL (validates website payment return/cancel URLs in production)
WEBSITE_URL=http://localhost:3000

# Website payment redirect paths (relative to WEBSITE_URL)
# Change only these when renaming success/fail pages — no code changes needed.
WEBSITE_PAYMENT_RETURN_PATH=/payment-return
WEBSITE_PAYMENT_FAILED_PATH=/payment-failed
WEBSITE_PAYMENT_SUCCESS_PATH=/mail-success
# Or override with full URLs:
# WEBSITE_PAYMENT_RETURN_URL=
# WEBSITE_PAYMENT_FAILED_URL=
# WEBSITE_PAYMENT_SUCCESS_URL=

# Mobile app deep-link scheme for app payment callbacks
APP_PAYMENT_SCHEME=mrcrafted

# Public API URL (used for hosted checkout page links)
API_PUBLIC_URL=http://localhost:8080

# Default webhook base URL (optional — used when gateway has no custom webhook URL)
# Falls back to API_PUBLIC_URL. Each gateway endpoint: {base}/api/payment/webhook/{gateway}
PAYMENT_WEBHOOK_BASE_URL=

# Super Admin (seeded on npm run seed)
SUPER_ADMIN_NAME=
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_MOBILE=
SUPER_ADMIN_PASSWORD=

# ─── Payment Gateways ───────────────────────────────────────────
# Store ONLY in .env — never in MongoDB.
# DB records store these variable NAMES only.

# Razorpay (default gateway)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_LIVE_KEY_ID=
RAZORPAY_LIVE_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# PhonePe
PHONEPE_TEST_MERCHANT_ID=
PHONEPE_TEST_SALT_KEY=
PHONEPE_LIVE_MERCHANT_ID=
PHONEPE_LIVE_SALT_KEY=
PHONEPE_WEBHOOK_SECRET=

# Cashfree
CASHFREE_TEST_APP_ID=
CASHFREE_TEST_SECRET_KEY=
CASHFREE_LIVE_APP_ID=
CASHFREE_LIVE_SECRET_KEY=
CASHFREE_WEBHOOK_SECRET=

# PayU
PAYU_TEST_MERCHANT_KEY=
PAYU_TEST_MERCHANT_SALT=
PAYU_LIVE_MERCHANT_KEY=
PAYU_LIVE_MERCHANT_SALT=

# Easebuzz
EASEBUZZ_TEST_KEY=
EASEBUZZ_TEST_SALT=
EASEBUZZ_LIVE_KEY=
EASEBUZZ_LIVE_SALT=

# Stripe
STRIPE_TEST_PUBLISHABLE_KEY=
STRIPE_TEST_SECRET_KEY=
STRIPE_LIVE_PUBLISHABLE_KEY=
STRIPE_LIVE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Paytm
PAYTM_TEST_MID=
PAYTM_TEST_MERCHANT_KEY=
PAYTM_LIVE_MID=
PAYTM_LIVE_MERCHANT_KEY=

# Cloudinary
CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email
EMAIL_USER=
EMAIL_PASS=
