  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "seed": "node src/seeders/initSeeder.js",
    "seed:gateways": "node -e \"import('dotenv').then(d=>d.config()); import('mongoose').then(async m=>{ await m.default.connect(process.env.MONGO_URI); const {seedPaymentGateways}=await import('./src/seeders/paymentGatewaySeeder.js'); await seedPaymentGateways(); process.exit(0); })\"",
    "migrate:rm-to-mr": "node src/migrations/renameRmToMr.js"
  },
