    "compression": "^1.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-async-handler": "^1.2.0",
    "express-rate-limit": "^8.2.1",
    "google-libphonenumber": "^3.2.42",
    "helmet": "^8.1.0",
